# Keep e2e byte-round-trip fixtures EXACT across platforms — no EOL conversion.
# The Gate 1 test asserts on-disk bytes; CRLF autoconversion would corrupt them.
e2e/fixtures/** -text

# PA-8 fixtures are scanned line-by-line; EOL is irrelevant but pin LF for stability.
test/fixtures/** text eol=lf

# Harness sources: normalize to LF in the repo.
scripts/** text eol=lf
e2e/**.ts text eol=lf
*.yml text eol=lf
