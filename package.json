{
  "name": "notepadse",
  "version": "0.0.0",
  "private": true,
  "description": "Electron + Fluent UI v9 + React + TypeScript 1:1 rewrite of the UWP Notepads app",
  "type": "module",
  "main": "out/main/index.js",
  "author": "Notepads-next team",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "measure": "node scripts/measure-nonfunctional.mjs",
    "dist": "vite build && electron-builder --publish never",
    "dist:dir": "vite build && electron-builder --dir --publish never",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:functional": "playwright test --grep-invert @visual",
    "visual:capture": "cross-env NOTEPADS_VISUAL_UPDATE=1 playwright test tabs-visual"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fluentui/react-components": "^9.74.1",
    "codemirror": "^6.0.2",
    "diff": "^9.0.0",
    "iconv-lite": "^0.7.2",
    "jschardet": "^3.1.4",
    "koffi": "^3.0.2",
    "markdown-it": "^14.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/diff": "^8.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "cross-env": "^10.1.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0",
    "jimp": "^1.6.1",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "pixelmatch": "^7.2.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-electron": "^1.0.4",
    "vitest": "^4.1.8"
  },
  "packageManager": "yarn@4.16.0"
}
