{
  "name": "notepade",
  "version": "1.0.0-beta.12",
  "private": true,
  "description": "Tauri + Fluent UI v9 + React + TypeScript 1:1 rewrite of the UWP Notepads app",
  "type": "module",
  "main": "out/renderer/index.html",
  "author": "Notepads-next team",
  "license": "GPL-3.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tauri dev",
    "build": "vite build",
    "tauri": "tauri",
    "dist": "tauri build",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:web",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e:electron-legacy": "playwright test",
    "visual:capture": "cross-env NOTEPADS_VISUAL_UPDATE=1 playwright test tabs-visual"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fluentui/react-components": "^9.74.1",
    "@mdit/plugin-abbr": "^0.23.2",
    "@mdit/plugin-alert": "^0.23.2",
    "@mdit/plugin-align": "^0.24.2",
    "@mdit/plugin-attrs": "^0.25.2",
    "@mdit/plugin-container": "^0.23.2",
    "@mdit/plugin-dl": "^0.23.2",
    "@mdit/plugin-emoji": "^0.2.2",
    "@mdit/plugin-figure": "^0.23.2",
    "@mdit/plugin-footnote": "^0.23.2",
    "@mdit/plugin-ins": "^0.23.2",
    "@mdit/plugin-mark": "^0.23.2",
    "@mdit/plugin-spoiler": "^0.23.2",
    "@mdit/plugin-sub": "^0.24.2",
    "@mdit/plugin-sup": "^0.24.2",
    "@mdit/plugin-tasklist": "^0.23.2",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "diff": "^9.0.0",
    "dompurify": "^3.4.8",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.2.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/diff": "^8.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "cross-env": "^10.1.0",
    "jimp": "^1.6.1",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "pixelmatch": "^7.2.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "packageManager": "yarn@4.16.0"
}
