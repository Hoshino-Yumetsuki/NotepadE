{
  "name": "notepads-next",
  "version": "0.0.0",
  "private": true,
  "description": "Electron + Fluent UI v9 + React + TypeScript 1:1 rewrite of the UWP Notepads app",
  "type": "module",
  "main": "out/main/index.js",
  "author": "Notepads-next team",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "pa8:scan": "tsx scripts/pa8-scan.ts",
    "pa8:scan:fixture": "tsx scripts/pa8-scan.ts --root test/fixtures/pa8-bad --renderer test/fixtures/pa8-bad/renderer --expect-fail",
    "pa8:scan:fixture-good": "tsx scripts/pa8-scan.ts --root test/fixtures/pa8-good --renderer test/fixtures/pa8-good/renderer",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:functional": "playwright test --grep-invert @visual",
    "visual:capture": "cross-env NOTEPADS_VISUAL_UPDATE=1 playwright test tabs-visual"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fluentui/react-components": "^9.74.1",
    "codemirror": "^6.0.2",
    "diff": "^9.0.0",
    "iconv-lite": "^0.7.2",
    "jschardet": "^3.1.4",
    "koffi": "^3.0.2",
    "markdown-it": "^14.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/diff": "^8.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.1",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitejs/plugin-react": "^6.0.2",
    "cross-env": "^10.1.0",
    "electron": "^42.3.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-electron": "^1.0.1",
    "vitest": "^4.1.8"
  },
  "packageManager": "yarn@4.16.0+sha512.5374c94eb4ef6aa8188fb112f20c1aa6569f248d676c5e576e1fd2a1a4d8d87a96df65d9dfe1c2a0252cbe38bda46cf18d955005b81b43cc7607a5c9d56fd2b6"
}
